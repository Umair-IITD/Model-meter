rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // PUBLIC AUDITS: readable by anyone, writable only via Admin SDK (which bypasses these rules)
    match /audits/{auditId} {
      allow read: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // LEADS: completely private — no client access ever
    match /leads/{leadId} {
      allow read: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
